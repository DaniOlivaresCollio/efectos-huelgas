aes(y = prop,
x = ola,
axis2 = class_2,
alluvium = idencuesta,
stratum = class_2,
fill = class_2)) +
theme_bw() +
ggalluvial::geom_flow(alpha = 0.66) +
ggalluvial::geom_stratum(width = 0.55, linetype=0) +
geom_text(stat = "stratum", aes(label = after_stat(stratum)), color = "black", size = 3) +
scale_x_discrete(limits = c("2016", "2017", "2018", "2019", "2021"), expand = c(.1, .1)) +
labs(title = "Gráfico Aluvial de la Variable 'Rama' a lo Largo de las Olas",
x = "Ola",
y = "Proporción") +
theme(legend.position = "bottom")
