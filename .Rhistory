data <- data %>%
mutate(identificacion_mov=car::recode(c21_02,
recodes=c("1='Totalmente en desacuerdo';
2='En desacuerdo';
3='Ni en desacuerdo ni de acuerdo';
4='De acuerdo';
5='Totalmente de acuerdo';
-888=NA;
-999=NA"),
as.factor=TRUE, # convertir a factor
levels=c("Totalmente en desacuerdo",
"En desacuerdo",
"Ni en desacuerdo ni de acuerdo",
"De acuerdo",
"Totalmente de acuerdo"))) # ordenar niveles
# Calcular frecuencias
tabla_freq_identificacion_ml <- data %>%
filter(mov_valora==2) %>%
group_by(ola,identificacion_mov) %>%
summarise(frecuencia=n()) %>%
ungroup()
# Crear tabla en formato wide
tabla_freq_identificacion_ml <- tabla_freq_identificacion_ml %>%
pivot_wider(names_from=ola,values_from=frecuencia,names_prefix="Ola_")
# Mostrar tabla
kable(tabla_freq_identificacion_ml,caption="Frecuencias de 'Grado de acuerdo: IdentificaciĂłn con el movimiento' por ola")
# Tabla de frecuencias y porcentajes
data_ml <- data %>%
filter(mov_valora==2)
sjt.xtab(data_ml$identificacion_mov,data_ml$ola,
show.col.prc = TRUE,
var.labels = c("IdentificaciĂłn con el movimiento DL","Ola"),
show.summary = FALSE,
title = "Frecuencias y porcentajes del Nivel de IdentificaciĂłn con el Movimiento de Demandas Laborales, por ola")
sjt.xtab(data_ml$compromiso_mov,data_ml$ola,
show.col.prc = TRUE,
var.labels = c("Compromiso con el movimiento DL","Ola"),
show.summary = FALSE,
title = "Frecuencias y porcentajes del Nivel de Compromiso con el Movimiento de Demandas Laborales, por ola")
