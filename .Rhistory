pivot_wider(names_from=ola,values_from=frecuencia,names_prefix="Ola_")%>%
rename_at(vars(starts_with("Ola_")), ~ levels(data$ola))
pivot_wider(names_from=levels(data$ola,values_from=frecuencia,names_prefix="Ola_")
