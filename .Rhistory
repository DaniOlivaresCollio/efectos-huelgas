cualificacion == "Unskilled" & supervisa == 1 ~ "Unskilled supervisors",
cualificacion == "Unskilled" & supervisa == 0 ~ "Workers"))
data$class <- factor(data$class,
levels = c("Self-employed",
"Expert managers",
"Experts",
"Skilled supervisors",
"Skilled workers",
"Unskilled supervisors",
"Workers"))
